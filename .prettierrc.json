{
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "overrides": [
    {
      "files": ["*.md"],
      "options": { "proseWrap": "preserve" }
    },
    { "files": ["hooks/pre-commit", "scripts/*.sh"], "options": { "singleQuote": false } }
  ]
}
